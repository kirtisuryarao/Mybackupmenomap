// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model - Core user account information
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  name           String
  age            Int?
  cycleLength    Int      @default(28) @map("cycle_length")
  periodDuration Int      @default(5) @map("period_duration")
  menopauseStage String   @default("regular") @map("menopause_stage")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  // Relations
  partners            Partner[]
  cycleEntries        CycleEntry[]
  dailyLogs           DailyLog[]
  healthLogs          HealthLog[]
  cycles              Cycle[]
  predictions         Prediction[]
  notificationSettings NotificationSettings?
  privacySettings     PrivacySettings?
  chatMessages        ChatMessage[]
  refreshTokens       RefreshToken[]
  consents            Consent[]

  @@map("users")
}

// Partner model - Partner account for accessing user's cycle data
model Partner {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  name           String
  email          String   @unique
  passwordHash   String   @map("password_hash")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens   PartnerRefreshToken[]
  consents        Consent[]

  @@unique([userId, email])
  @@index([userId])
  @@index([email])
  @@map("partners")
}

// PartnerRefreshToken model - JWT refresh tokens for partner sessions
model PartnerRefreshToken {
  id        String   @id @default(cuid())
  partnerId String   @map("partner_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([token])
  @@map("partner_refresh_tokens")
}

model Consent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  partnerId String   @map("partner_id")
  scopes    String[]
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([partnerId])
  @@index([expiresAt])
  @@map("consents")
}

// CycleEntry model - Historical cycle tracking data
model CycleEntry {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  lastPeriodDate DateTime @map("last_period_date")
  cycleLength    Int      @map("cycle_length")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastPeriodDate])
  @@map("cycle_entries")
}

// NotificationSettings model - User notification preferences
model NotificationSettings {
  id                String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  periodReminder     Boolean  @default(true) @map("period_reminder")
  phaseChange        Boolean  @default(true) @map("phase_change")
  pushNotifications  Boolean  @default(false) @map("push_notifications")
  emailNotifications Boolean  @default(false) @map("email_notifications")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

// PrivacySettings model - User privacy preferences
model PrivacySettings {
  id                String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  profilePublic      Boolean  @default(false) @map("profile_public")
  shareWithPartner   Boolean  @default(false) @map("share_with_partner")
  allowHealthInsight Boolean  @default(true) @map("allow_health_insight")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

// ChatMessage model - AI chatbot conversation history
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      String   // 'user' or 'assistant'
  content   String   @db.Text
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@map("chat_messages")
}

// RefreshToken model - For JWT refresh token rotation
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// DailyLog model - User daily tracking data (period, mood, symptoms, temperature)
model DailyLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  date        DateTime @db.Date
  flow        String?  // 'light', 'medium', 'heavy', 'super_heavy'
  spotting    String?  // 'red', 'brown'
  mood        String[] // array: ['happy', 'sad', 'anxious', etc.]
  symptoms    String[] // array: ['cramps', 'headache', 'fatigue', etc.]
  temperature Float?   // basal body temperature
  sleepQuality String? @map("sleep_quality") // 'good', 'fair', 'poor'
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("daily_logs")
}

model HealthLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  date       DateTime @db.Date
  symptoms   Json
  mood       String?
  sleepHours Float?   @map("sleep_hours")
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("health_logs")
}

// Cycle model - Detected cycle history (start/end dates, computed length)
model Cycle {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  startDate DateTime  @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  length    Int?      // calculated cycle length in days
  periodLength Int?   @map("period_length") // days of bleeding
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate])
  @@map("cycles")
}

// Prediction model - Predicted dates for next period, ovulation, fertile window
model Prediction {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  predictedPeriodDate  DateTime @map("predicted_period_date") @db.Date
  ovulationDate        DateTime @map("ovulation_date") @db.Date
  fertileWindowStart   DateTime @map("fertile_window_start") @db.Date
  fertileWindowEnd     DateTime @map("fertile_window_end") @db.Date
  confidence           Float    @default(0.5) // 0-1 confidence score
  method               String   @default("rule_based") // 'rule_based' or 'ml'
  createdAt            DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("predictions")
}
